    { "source": "/careers/contract-job-openings/",                "destination": "https://starworkforce.net/pages/jobs", "permanent": true },
    { "source": "/careers/benefits",                              "destination": "https://starworkforce.net/pages/jobs", "permanent": true },
    { "source": "/careers/benefits/",                             "destination": "https://starworkforce.net/pages/jobs", "permanent": true },
    { "source": "/careers/benefits/employee-referral-incentive",  "destination": "https://starworkforce.net/pages/jobs", "permanent": true },
    { "source": "/careers/benefits/employee-referral-incentive/", "destination": "https://starworkforce.net/pages/jobs", "permanent": true },
    { "source": "/careers/meet-our-people",                       "destination": "/about",            "permanent": true },
    { "source": "/careers/meet-our-people/",                      "destination": "/about",            "permanent": true },
    { "source": "/careers/culture-at-startekk",                   "destination": "/about",            "permanent": true },
    { "source": "/careers/culture-at-startekk/",                  "destination": "/about",            "permanent": true },
    { "source": "/careers/about-us",                              "destination": "/about",            "permanent": true },
    { "source": "/careers/about-us/",                             "destination": "/about",            "permanent": true },
    { "source": "/careers/terms-of-use-and-eeo-policy",           "destination": "/legal/terms-of-service", "permanent": true },
