    { "source": "/investor/contact",                "destination": "/contact",           "permanent": true },
    { "source": "/investor/contact.html",           "destination": "/contact",           "permanent": true },
    { "source": "/investor/star-automation.html",   "destination": "/star-automation",   "permanent": true },
    { "source": "/investor/star-ai-finance.html",   "destination": "/star-ai-finance",   "permanent": true },
    { "source": "/investor/star-ai-cloud.html",     "destination": "/star-ai-cloud",     "permanent": true },
    { "source": "/investor/star-ai-ediscovery.html","destination": "/star-ai-ediscovery","permanent": true },
    { "source": "/investor/qr-feedback.html",       "destination": "/qr-feedback",       "permanent": true },

    { "source": "/terms-of-use-and-eeo-policy",  "destination": "/legal/terms-of-service", "permanent": true },
    { "source": "/terms-of-use-and-eeo-policy/", "destination": "/legal/terms-of-service", "permanent": true },

    { "source": "/legal/data-processing.html", "destination": "/legal/privacy-policy", "permanent": true },
    { "source": "/legal/data-processing",      "destination": "/legal/privacy-policy", "permanent": true },

    { "source": "/blog/posts/:path*", "destination": "/blog", "permanent": true },
    { "source": "/blog.html",         "destination": "/blog",  "permanent": true },

    { "source": "/products/rebuix",  "destination": "/", "permanent": true },
    { "source": "/products/rebuix/", "destination": "/", "permanent": true },

    { "source": "/pages/jobs.html", "destination": "/pages/jobs", "permanent": true },

    { "source": "/jobs",  "destination": "/pages/jobs", "permanent": true },
    { "source": "/jobs/", "destination": "/pages/jobs", "permanent": true },

    { "source": "/location",  "destination": "/contact", "permanent": true },
    { "source": "/location/", "destination": "/contact", "permanent": true },

    { "source": "/m",  "destination": "/", "permanent": true },
    { "source": "/m/", "destination": "/", "permanent": true },

    { "source": "/index.html",    "destination": "/",       "permanent": true },
    { "source": "/:path*.html",   "destination": "/:path*", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Link",                    "value": "<https://www.startekk.net$1>; rel=\"canonical\"" }
      ]
    }
  ]
}
